[solution]
name = SnakeGame
configurations = Debug, Release
platforms = x64

include = 3rdparty/3rdparty.buildscript

[project:SnakeGame]
type = exe
sources = src/**/*.cpp
headers = src/**/*.h
includes = src
std = 20

# Compiler settings
multiprocessor = true
warning_level = Level3

if(Windows)
{
    subsystem = Windows
    target_link_libraries(SDL3)
}

if(Linux)
{
    includes = ${SDL3_INCLUDE_DIRS}
    libs = ${SDL3_LIBRARIES}
    libdirs = ${SDL3_LIBRARY_DIRS}
}